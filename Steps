3. Docker Containerization

Step 1: Create Dockerfile

FROM nginx:alpine
COPY . /usr/share/nginx/html


---

Step 2: Build Image

docker build -t university-web .


---

Step 3: Run Container

docker run -d -p 8080:80 university-web

Open browser:
👉 http://localhost:8080


---

4. Jenkins Pipeline (CI/CD)

Step 1: Create Jenkins Pipeline Project

Open Jenkins

Click New Item

Select Pipeline

Name: University-Web-Pipeline



---

Step 2: Pipeline Script

pipeline {
    agent any

    stages {

        stage('Clone') {
            steps {
                git 'https://github.com/your-username/university-department-webpage.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t university-web .'
            }
        }

        stage('Run Container') {
            steps {
                sh 'docker run -d -p 8080:80 university-web'
            }
        }

    }
}


---

5. Kubernetes Deployment

Step 1: Create deployment.yaml

apiVersion: apps/v1
kind: Deployment
metadata:
  name: university-deployment
spec:
  replicas: 2
  selector:
    matchLabels:
      app: university
  template:
    metadata:
      labels:
        app: university
    spec:
      containers:
      - name: university-container
        image: university-web
        ports:
        - containerPort: 80


---

Step 2: Service File service.yaml

apiVersion: v1
kind: Service
metadata:
  name: university-service
spec:
  type: NodePort
  selector:
    app: university
  ports:
    - port: 80
      targetPort: 80
      nodePort: 30007


---

Step 3: Apply in Kubernetes

kubectl apply -f deployment.yaml
kubectl apply -f service.yaml
kubectl get pods
kubectl get services


